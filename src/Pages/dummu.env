const SignUp = () => {
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [mascot, setMascot] = useState('🧐'); // Neutral state
  const [isSubmitting, setIsSubmitting] = useState(false);

  // Funny Interaction: Mascot reacts to password length
  useEffect(() => {
    if (password.length === 0) setMascot('🧐');
    else if (password.length < 6) setMascot('🤨'); // Judging short passwords
    else if (password.length < 12) setMascot('😮'); // Impressed
    else setMascot('😎'); // Super secure!
  }, [password]);